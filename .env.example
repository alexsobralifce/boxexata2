# ==========================================
# CONFIGURAÇÕES DO EXATABOT E EVOLUTION API
# ==========================================

# --- Evolution API Gateway ---
# URL da API de Integração com o WhatsApp
EVOLUTION_API_URL=http://localhost:8080

# Chave secreta global para autenticação na Evolution API (crie uma chave forte)
EVOLUTION_API_KEY=sua_chave_secreta_global_aqui

# Nome da instância que o bot utilizará no WhatsApp
EVOLUTION_INSTANCE=exatabot

# --- Configurações do Chatbot ---
# Nome de exibição da atendente virtual do bot
BOT_NAME=Ana

# Horário de início do atendimento comercial (formato 24h, ex: 8 para 08:00)
BUSINESS_HOURS_START=8

# Horário de término do atendimento comercial (formato 24h, ex: 18 para 18:00)
BUSINESS_HOURS_END=18

# --- Scraper & Dados ---
# URL base do site de imóveis para scraping
SITE_BASE_URL=https://www.exataservicos.net

# Tempo de vida útil do cache em minutos para evitar requisições duplicadas ao site
CACHE_TTL_MINUTES=30

# Quantidade de imóveis exibidos por página de resultados na conversa
RESULTS_PAGE_SIZE=3

# Limite máximo de fotos enviadas por imóvel no detalhamento
MAX_PHOTOS_PER_PROPERTY=3

# --- Inteligência Artificial (Opcional - Fase 6) ---
# Escolha o provedor de extração de intenções/preferências ("regex", "openai" ou "deepseek")
LLM_PROVIDER=regex

# Chave de API da OpenAI (se LLM_PROVIDER for "openai")
OPENAI_API_KEY=

# Chave de API da DeepSeek (se LLM_PROVIDER for "deepseek")
DEEPSEEK_API_KEY=

# --- Redis (Fase 6) ---
# URL do servidor Redis
REDIS_URL=redis://localhost:6379/0

# Tipo de persistência de sessão ("memory" ou "redis")
SESSION_STORE_TYPE=memory

# Tipo de cache para o scraper ("memory" ou "redis")
CACHE_TYPE=memory

# --- Alertas Proativos (Fase 7) ---
# Tipo de armazenamento de assinaturas ("memory" ou "redis")
SUBSCRIPTION_STORE_TYPE=memory

# Intervalo de checagem de novos imóveis em minutos
NOTIFY_CHECK_INTERVAL_MINUTES=15

# --- Banco de Dados e Logs (Fase 8A) ---
# Habilitar persistência de logs de mensagens (true/false)
MESSAGE_LOG_ENABLED=false

# URL de conexão assíncrona ao banco de dados PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/exatabot

# --- Painel Administrativo & Segurança JWT (Fase 8C) ---
# Usuário de login do painel administrativo
ADMIN_USERNAME=admin

# Hash bcrypt da senha de administrador (use bcrypt para gerar um hash seguro, ex: para "admin123")
# Hash correspondente a "admin123" (para fins de teste/exemplo):
ADMIN_PASSWORD_HASH=$2b$12$Zsz0GgBqN/7WJ9DkC/3F7un69K1FzH8p.zG9T6jH6y6.2.X7.xW.O

# Chave secreta para assinatura dos tokens JWT (gere uma string longa e aleatória)
JWT_SECRET_KEY=sua_chave_secreta_super_secreta_aqui

